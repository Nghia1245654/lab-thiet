# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all variables files except standard templates
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include lock file (recommended for team setups, but can ignore if preferred)
# !.terraform.lock.hcl

# Python / Lambda cache and builds
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.coverage
**/htmlcov/

# Lambda packages
**/lambda.zip

# OS files
.DS_Store
Thumbs.db

# Secrets
.env
.env.*
